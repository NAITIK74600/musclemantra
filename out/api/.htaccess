# Muscle Mantra — API directory rules
# Disables ModSecurity WAF rules that block JSON POST requests (415 error)

<IfModule mod_security2.c>
    SecRuleEngine Off
</IfModule>

# Allow JSON and multipart content types
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
</IfModule>

# Pass the Authorization header through to PHP.
# On cPanel / FastCGI, Apache strips the Authorization header by default, which
# makes Bearer-token admin auth silently fail — the admin panel then shows empty
# lists (orders, trainer bookings, coupons, etc.). These rules restore it.
#
# IMPORTANT: enabling RewriteEngine in this sub-directory STOPS Apache from
# inheriting the parent (site root) rewrite rules — including the one that maps
# an extensionless endpoint (/api/admin/login) to its real file (login.php).
# Without that, every /api/* call 404s. So we re-declare the .php mapping here.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Restore the Authorization header for Bearer-token admin auth.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Map /api/<endpoint> -> /api/<endpoint>.php (parent rule is not inherited).
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# Block direct access to config and helper files
<FilesMatch "^(_config|db|env|mailer|guard|delivery-helpers|invoice-pdf)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct access to the secrets file (.env / .env.example)
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

# PHP settings for uploads
php_value upload_max_filesize 10M
php_value post_max_size 12M
php_value max_execution_time 60
