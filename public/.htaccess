Options -Indexes
Options +FollowSymLinks
RewriteEngine On
RewriteBase /

# ── Security: block sensitive files ──────────────────────────────────────────
RewriteRule ^api/_config\.php$ - [F,L]
RewriteRule ^data/ - [F,L]
RewriteRule ^\..*$ - [F,L]

# ── Security headers (requires mod_headers — works on most cPanels) ──────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Handle existing files and directories first ───────────────────────────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── API routing: /api/endpoint → /api/endpoint.php ──────────────────────────
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.+)$ $1.php [L]

# ── Next.js SPA fallback — serve index.html for all unknown routes ────────────
RewriteRule ^ /index.html [L]
