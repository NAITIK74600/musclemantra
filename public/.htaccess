Options -Indexes
Options +FollowSymLinks
RewriteEngine On
RewriteBase /

# ── Security: block sensitive files ──────────────────────────────────────────
RewriteRule ^api/db\.php$      - [F,L]
RewriteRule ^api/_config\.php$ - [F,L]
RewriteRule ^data/ - [F,L]
# Block everything under /setup/ EXCEPT install.php (needed for one-time DB setup)
RewriteCond %{REQUEST_URI} !^/setup/install\.php$
RewriteRule ^setup/ - [F,L]
RewriteRule ^\..*$ - [F,L]

# ── Security headers (requires mod_headers — works on most cPanels) ──────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Handle existing files and directories first ───────────────────────────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── API routing: /api/endpoint → /api/endpoint.php ──────────────────────────
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.+)$ $1.php [L]

# ── Static-export page routing ───────────────────────────────────────────────
# Every page is exported as <route>/index.html (trailingSlash: true). If a
# request arrives WITHOUT a trailing slash (e.g. /about, /brands), map it to
# its exported HTML so nav links never fall through to the homepage.
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ /$1/index.html [L]

# ── Unknown routes → the exported 404 page (never the homepage) ──────────────
ErrorDocument 404 /404.html
RewriteRule ^ /404.html [L]
