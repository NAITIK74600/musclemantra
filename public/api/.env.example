# Muscle Mantra — environment secrets
# ---------------------------------------------------------------
# HOW TO USE (once, on the server):
#   1. In cPanel File Manager, go to  public_html/api/
#   2. Copy this file  .env.example  ->  .env   (same folder)
#   3. Edit .env and put your REAL database password in DB_PASS
#   4. Save. That's it — you never touch it again.
#
# This .env file is NOT part of the deploy, so "Deploy HEAD Commit"
# will never overwrite it. It is also blocked from the web by .htaccess.
# ---------------------------------------------------------------

# MySQL database (from cPanel -> MySQL Databases)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=musclema_store
DB_USER=musclema_admin
DB_PASS=your_db_password_here

# Admin key (used by the admin panel + setup script)
ADMIN_KEY=Amarjeetmuscle@321

# PayU payment gateway
PAYU_KEY=uB3THG
PAYU_SALT=JfzpDUF94Ix2YE5cCxgjmm2LoxWewsJs
PAYU_MODE=test

# Email
MAIL_FROM=noreply@musclemantra.shop
MAIL_FROM_NAME=Muscle Mantra
MAIL_REPLY_TO=admin@musclemantra.shop

# Site
SITE_URL=https://musclemantra.shop
